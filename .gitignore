# --- COMPILATION ARTIFACTS ---
# The entire build directory. Never track this.
/target/

# --- LOGS & TELEMETRY ---
# Local log files generated during testing.
*.log

# --- OS & IDE NOISE ---
# macOS specific
.DS_Store
# VS Code / JetBrains local settings
.vscode/
.idea/
*.swp
*~

# --- SECRETS & ENVIRONMENT ---
# Never track tactical secrets or local environment overrides.
.env
.env.*

# --- RUST SPECIFIC ---
# Backup files generated by cargo-fmt
*.rs.bk